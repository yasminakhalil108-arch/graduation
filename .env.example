# ============================================
# EDGE FUNCTION SECRETS (Set in Supabase Dashboard)
# ============================================
# These are NOT .env variables. Set them in:
# Supabase Dashboard → Edge Functions → Secrets

# Your OpenAI API Key
# Get from: https://platform.openai.com/api-keys
# Set as: OPENAI_API_KEY
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxx

# (Optional) OpenAI Model to use
# Default: gpt-4o-mini
# Other options: gpt-4, gpt-3.5-turbo
# Set as: OPENAI_MODEL
OPENAI_MODEL=gpt-4o-mini

# ============================================
# DEVELOPMENT SETTINGS
# ============================================

# Your app environment
VITE_API_ENV=development

# Debug mode (set to 'true' for verbose logs)
DEBUG=false

# ============================================
# HOW TO USE THIS FILE
# ============================================

# 1. Copy this file to: .env.local
# 2. Fill in your actual values above
# 3. For production: use .env.production

# ============================================
# EDGE FUNCTION SECRETS SETUP
# ============================================

# To set Edge Function secrets:
# Option A: CLI
#   supabase secrets set OPENAI_API_KEY=sk-xxxx...
#
# Option B: Dashboard
#   1. Go to Supabase Project
#   2. Navigate to: Edge Functions → Secrets
#   3. Add: OPENAI_API_KEY with your OpenAI key
#   4. (Optional) Add: OPENAI_MODEL if not using default

# ============================================
# VERIFYING SETUP
# ============================================

# After setup, verify:
# 1. SQL schema applied? Go to Database → Tables (should see 4 new tables)
# 2. Edge Function deployed? Go to Edge Functions (should see summarize-thread-openai)
# 3. Secrets set? Go to Edge Functions → Secrets (should see OPENAI_API_KEY)
# 4. thread-manager.js in place? Check: knowledge-hub.html/thread-manager.js
# 5. Demo page working? Open: messaging-demo.html in browser

# ============================================
# TROUBLESHOOTING
# ============================================

# "Missing env var: OPENAI_API_KEY"
#   → Go to Supabase Edge Functions → Secrets
#   → Add: OPENAI_API_KEY = sk-xxxxx

# "Invalid auth" from Edge Function
#   → Check Supabase URL and Key are correct
#   → Verify user is logged in

# "No messages found"
#   → Send messages before generating summary
#   → Check message thread_id matching

# RLS deny errors
#   → Verify user is in thread_members table
#   → Check RLS policies in Database → Policies
